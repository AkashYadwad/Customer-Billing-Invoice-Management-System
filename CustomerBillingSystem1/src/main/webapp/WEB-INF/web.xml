<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>BillingApp</display-name>

    <servlet>
        <servlet-name>AddCustomerServlet</servlet-name>
        <servlet-class>com.billing.controller.AddCustomerServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>AddCustomerServlet</servlet-name>
        <url-pattern>/addCustomer</url-pattern>
    </servlet-mapping>

    <servlet>
    <servlet-name>ViewCustomersServlet</servlet-name>
    <servlet-class>com.billing.controller.ViewCustomersServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>ViewCustomersServlet</servlet-name>
    <url-pattern>/viewCustomers</url-pattern>
</servlet-mapping>
  <servlet>
    <servlet-name>DeleteCustomerServlet</servlet-name>
    <servlet-class>com.billing.controller.DeleteCustomerServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>DeleteCustomerServlet</servlet-name>
    <url-pattern>/deleteCustomer</url-pattern>
</servlet-mapping>
<servlet>
    <servlet-name>EditCustomerServlet</servlet-name>
    <servlet-class>com.billing.controller.EditCustomerServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>EditCustomerServlet</servlet-name>
    <url-pattern>/editCustomer</url-pattern>
</servlet-mapping>

<servlet>
    <servlet-name>UpdateCustomerServlet</servlet-name>
    <servlet-class>com.billing.controller.UpdateCustomerServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>UpdateCustomerServlet</servlet-name>
    <url-pattern>/updateCustomer</url-pattern>
</servlet-mapping>
<servlet>
    <servlet-name>AddProductServlet</servlet-name>
    <servlet-class>com.billing.controller.AddProductServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>AddProductServlet</servlet-name>
    <url-pattern>/addProduct</url-pattern>
</servlet-mapping>
<servlet>
    <servlet-name>ViewProductsServlet</servlet-name>
    <servlet-class>com.billing.controller.ViewProductsServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>ViewProductsServlet</servlet-name>
    <url-pattern>/viewProducts</url-pattern>
</servlet-mapping>
<servlet>
    <servlet-name>DeleteProductServlet</servlet-name>
    <servlet-class>com.billing.controller.DeleteProductServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>DeleteProductServlet</servlet-name>
    <url-pattern>/deleteProduct</url-pattern>
</servlet-mapping>
<servlet>
    <servlet-name>EditProductServlet</servlet-name>
    <servlet-class>com.billing.controller.EditProductServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>EditProductServlet</servlet-name>
    <url-pattern>/editProduct</url-pattern>
</servlet-mapping>

<servlet>
    <servlet-name>UpdateProductServlet</servlet-name>
    <servlet-class>com.billing.controller.UpdateProductServlet</servlet-class>
</servlet>

<servlet-mapping>
    <servlet-name>UpdateProductServlet</servlet-name>
    <url-pattern>/updateProduct</url-pattern>
</servlet-mapping>

</web-app>